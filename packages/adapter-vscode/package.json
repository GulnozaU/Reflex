{
  "name": "reflex",
  "displayName": "Reflex",
  "description": "Local-first workflow memory layer for coding agents and IDEs (Cursor and VS Code)",
  "version": "0.1.5",
  "publisher": "reflex",
  "private": true,
  "repository": {
    "type": "git",
    "url": "https://github.com/GulnozaU/Reflex"
  },
  "license": "MIT",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "reflex.enable",
        "title": "Enable Reflex",
        "category": "Reflex"
      },
      {
        "command": "reflex.showActivity",
        "title": "Show Activity",
        "category": "Reflex"
      },
      {
        "command": "reflex.statusBarClick",
        "title": "Status Bar",
        "category": "Reflex"
      },
      {
        "command": "aiSkillEvolution.showProbe",
        "title": "Show Activity (legacy)",
        "category": "Reflex"
      },
      {
        "command": "aiSkillEvolution.resetConsent",
        "title": "Reset & Enable",
        "category": "Reflex"
      },
      {
        "command": "aiSkillEvolution.probeTerminal",
        "title": "Show Activity (dev)",
        "category": "Reflex"
      }
    ],
    "menus": {
      "commandPalette": [
        {
          "command": "reflex.statusBarClick",
          "when": "false"
        },
        {
          "command": "aiSkillEvolution.showProbe",
          "when": "false"
        },
        {
          "command": "aiSkillEvolution.probeTerminal",
          "when": "false"
        }
      ]
    },
    "configuration": {
      "title": "Reflex",
      "properties": {
        "aiSkillEvolution.logTerminalProbe": {
          "type": "boolean",
          "default": true,
          "description": "Log file and terminal capture events to the Reflex output panel"
        }
      }
    }
  },
  "scripts": {
    "build": "webpack --mode production",
    "watch": "webpack --mode development --watch",
    "stage:sqljs": "node ./scripts/stage-sqljs.js",
    "package": "npm run build && npm run stage:sqljs && cp ../../LICENSE LICENSE && vsce package --no-dependencies && rm -f LICENSE"
  },
  "dependencies": {
    "@ai-skill/skill-core": "0.1.0",
    "sql.js": "^1.10.2"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "@types/vscode": "^1.85.0",
    "ts-loader": "^9.5.1",
    "typescript": "^5.3.3",
    "@vscode/vsce": "^3.2.1",
    "webpack": "^5.90.0",
    "webpack-cli": "^5.1.4"
  }
}
